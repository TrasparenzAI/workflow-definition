                "connectionTimeOut": 120000,
                "readTimeOut": 120000
              }
            },
            "type": "HTTP_WEBCLIENT",
            "retryCount": 0,
            "optional": true,
            "asyncComplete": false
        },
        {
            "name": "Result JSON End workflow",
            "taskReferenceName": "result_json_end_workflow_ref",
            "inputParameters": {
              "id":"${result_get_workflow_ref.output.response.body.content[0].id}",
