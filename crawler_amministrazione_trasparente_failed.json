            "inputParameters": {
              "http_request": {
                "uri": "${workflow.input.result_base_url}/v1/workflows",
                "body": "${result_json_end_workflow_ref.output.result}",
                "method": "POST",
                "connectionTimeOut": 120000,
                "readTimeOut": 120000
