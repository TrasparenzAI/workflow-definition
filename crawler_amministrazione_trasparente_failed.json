              "rootRule": "${workflow.input.root_rule}",
              "status": "${workflow.input.failureStatus}",
              "createTime": "${result_get_workflow_ref.output.response.body.content[0].createTime}",              
              "startTime": "${result_get_workflow_ref.output.response.body.content[0].startTime}",              
              "endTime": "${get_current_time_failed_ref.output.result}",              
              "queryExpression": "{id: .id, workflowId: .workflowId, codiceIpa: .codiceIpa, rootRule: .rootRule, status: .status, startTime: .startTime, createTime: .createTime, endTime: .endTime}"
            },
            "type": "JSON_JQ_TRANSFORM",
            "retryCount": 0,
            "startDelay": 0,
            "optional": true,
            "asyncComplete": false
        },
        {
            "name": "Result END Workflow",
